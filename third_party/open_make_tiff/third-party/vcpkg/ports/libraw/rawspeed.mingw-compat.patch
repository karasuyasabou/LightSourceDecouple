diff --git a/RawSpeed/Common.cpp b/RawSpeed/Common.cpp
--- a/RawSpeed/Common.cpp
+++ b/RawSpeed/Common.cpp
@@ -36,5 +36,13 @@ int rawspeed_get_number_of_processor_cores()
